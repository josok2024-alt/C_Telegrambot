# Copy this file to .env and fill in your real keys. Never commit .env.

# Deriv (https://api.deriv.com — register an app to get your own app_id,
# then generate an API token at https://app.deriv.com/account/api-token
# Start with a DEMO account token. Grant "Trade" + "Read" scopes.)
DERIV_APP_ID=1089
DERIV_API_TOKEN=
DERIV_IS_DEMO=true

# Groq (https://console.groq.com/keys)
GROQ_API_KEY=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Telegram bot (create via @BotFather, get chat id via @userinfobot or /getUpdates)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Market data grounding (both free tier — optional but strongly recommended)
# TwelveData: https://twelvedata.com (free tier: 800 req/day, forex+crypto+indices)
TWELVEDATA_API_KEY=
# NewsData.io: https://newsdata.io (free tier: 200 req/day, business/forex news)
NEWSDATA_API_KEY=

LOG_LEVEL=INFO
